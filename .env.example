# NammaDeal Backend
# ─────────────────────────────────────────────────────────────
# ONDC Credentials (Fill after running: npm run keygen)
ONDC_SUBSCRIBER_ID=nammadeal.app
ONDC_UNIQUE_KEY_ID=nammadeal-key-1
ONDC_SIGNING_PRIVATE_KEY=       # Ed25519 private key (base64) - generated by npm run keygen
ONDC_SIGNING_PUBLIC_KEY=        # Ed25519 public key (base64)  - generated by npm run keygen
ONDC_ENCRYPTION_PRIVATE_KEY=    # X25519 private key (base64)  - generated by npm run keygen
ONDC_ENCRYPTION_PUBLIC_KEY=     # X25519 public key (base64)   - generated by npm run keygen

# ONDC Gateway URLs
ONDC_GATEWAY_URL=https://staging.registry.ondc.org/ondc     # Staging
# ONDC_GATEWAY_URL=https://prod.ondc.org/ondc               # Production

# Firebase (copy from your firebase.ts config)
FIREBASE_PROJECT_ID=nammadeal-870a6

# Server
PORT=3000
NODE_ENV=development
